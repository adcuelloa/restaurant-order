{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "start": {},
    "start:dev": {
      "cache": false,
      "persistent": true
    },
    "start:offline": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "lint:fix": {},
    "format": {},
    "format:check": {},
    "typecheck": {},
    "type-check": {},
    "test": {}
  }
}
