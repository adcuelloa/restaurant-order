{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "start": "node dist/main.mjs",
    "start:dev": "tsx watch src/main.ts",
    "start:offline": "serverless offline",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\" \"*.{js,json,yml,yaml}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json,md}\" \"*.{js,json,yml,yaml}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "infra:base": "docker compose -f infra/docker-compose.dev.yml",
    "infra:up": "pnpm infra:base up -d",
    "infra:down": "pnpm infra:base down",
    "infra:ps": "pnpm infra:base ps",
    "infra:logs": "pnpm infra:base logs -f",
    "infra:restart": "pnpm infra:down && pnpm infra:up",
    "infra:clean": "pnpm infra:base down -v --rmi local",
    "seed": "tsx scripts/seed-items.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/platform-express": "^11.1.16",
    "@vendia/serverless-express": "^4.12.6",
    "express": "^5.2.1",
    "mongoose": "^9.3.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.0.0",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/aws-lambda": "^8.10.145",
    "@types/express": "^5.0.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.4.2",
    "serverless": "^4.33.0",
    "serverless-offline": "^14.3.3",
    "tsdown": "^0.21.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
